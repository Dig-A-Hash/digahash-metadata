{
  "name": "digahash-metadata",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm -r --parallel --if-present dev",
    "test": "pnpm -r --if-present test",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "docker:install": "docker run --rm -it -v \"$(pwd):/app\" -w /app node:24-slim sh -lc \"corepack enable && pnpm install\"",
    "docker:build": "docker run --rm -it -v \"$(pwd):/app\" -w /app node:24-slim sh -lc \"corepack enable && pnpm -r build\""
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@types/node": "^24.0.0",
    "typescript": "5.8.2",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.1.2"
  },
  "pnpm": {
    "overrides": {
      "typescript": "5.8.2"
    }
  }
}
