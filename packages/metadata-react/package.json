{
  "name": "@digahash/metadata-react",
  "version": "1.0.0",
  "description": "React hooks for Digahash metadata.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "dependencies": {
    "@digahash/metadata-core": "^1.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "lint": "echo 'No lint configured for metadata-react'",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/react": "^19.1.13",
    "react": "^19.1.1",
    "@vitejs/plugin-react": "^4.5.0"
  }
}
