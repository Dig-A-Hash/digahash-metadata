{
  "name": "@digahash/metadata-vue",
  "version": "1.0.0",
  "description": "Vue 3 composables for Digahash metadata.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "dependencies": {
    "@digahash/metadata-core": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "lint": "echo 'No lint configured for metadata-vue'",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "vue": "^3.5.13"
  }
}
