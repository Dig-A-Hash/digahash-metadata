{
  "name": "@digahash/metadata-core",
  "version": "1.0.0",
  "description": "Framework-agnostic metadata state and utilities for Digahash.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "lint": "echo 'No lint configured for metadata-core'",
    "typecheck": "tsc --noEmit"
  }
}
